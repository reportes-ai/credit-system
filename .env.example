DB_HOST=tu-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=railway

# ─── SERVIDOR ─────────────────────────────────────────────────
PORT=3000

# ─── SEGURIDAD JWT ────────────────────────────────────────────
