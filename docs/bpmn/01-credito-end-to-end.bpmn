<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Defs_Credito_EndToEnd" targetNamespace="http://autofacil.cl/bpmn">
  <bpmn:process id="Credito_EndToEnd" name="Proceso de Crédito (end-to-end)" isExecutable="false">
    <bpmn:startEvent id="s" name="Carga masiva Excel / Digitación">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t1" name="Operación creada (INGRESO)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t2" name="Revisión del analista de crédito">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g1" name="¿Aprueba el crédito?">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e1" name="RECHAZADO">
      <bpmn:incoming>f4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t3" name="APROBADO">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g2" name="¿Se otorga la operación?">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e2" name="NO OTORGADO">
      <bpmn:incoming>f7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t4" name="OTORGADO">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="sp" name="Post Venta: fundantes → liberación → pago saldo → cartola → comisión">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e3" name="Operación VIGENTE / cerrada">
      <bpmn:incoming>f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="s" targetRef="t1" />
    <bpmn:sequenceFlow id="f2" sourceRef="t1" targetRef="t2" />
    <bpmn:sequenceFlow id="f3" sourceRef="t2" targetRef="g1" />
    <bpmn:sequenceFlow id="f4" sourceRef="g1" targetRef="e1" name="No" />
    <bpmn:sequenceFlow id="f5" sourceRef="g1" targetRef="t3" name="Sí" />
    <bpmn:sequenceFlow id="f6" sourceRef="t3" targetRef="g2" />
    <bpmn:sequenceFlow id="f7" sourceRef="g2" targetRef="e2" name="No" />
    <bpmn:sequenceFlow id="f8" sourceRef="g2" targetRef="t4" name="Sí" />
    <bpmn:sequenceFlow id="f9" sourceRef="t4" targetRef="sp" />
    <bpmn:sequenceFlow id="f10" sourceRef="sp" targetRef="e3" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Credito_EndToEnd_diagram">
    <bpmndi:BPMNPlane id="Credito_EndToEnd_plane" bpmnElement="Credito_EndToEnd">
      <bpmndi:BPMNShape id="s_di" bpmnElement="s">
        <omgdc:Bounds x="222" y="92" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t1_di" bpmnElement="t1">
        <omgdc:Bounds x="160" y="212" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t2_di" bpmnElement="t2">
        <omgdc:Bounds x="160" y="352" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g1_di" bpmnElement="g1" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="505" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e1_di" bpmnElement="e1">
        <omgdc:Bounds x="482" y="512" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t3_di" bpmnElement="t3">
        <omgdc:Bounds x="160" y="632" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g2_di" bpmnElement="g2" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="785" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e2_di" bpmnElement="e2">
        <omgdc:Bounds x="482" y="792" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t4_di" bpmnElement="t4">
        <omgdc:Bounds x="160" y="912" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="sp_di" bpmnElement="sp">
        <omgdc:Bounds x="145" y="1042" width="190" height="96" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e3_di" bpmnElement="e3">
        <omgdc:Bounds x="222" y="1212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <omgdi:waypoint x="240" y="128" />
        <omgdi:waypoint x="240" y="212" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <omgdi:waypoint x="240" y="288" />
        <omgdi:waypoint x="240" y="352" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <omgdi:waypoint x="240" y="428" />
        <omgdi:waypoint x="240" y="505" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <omgdi:waypoint x="265" y="530" />
        <omgdi:waypoint x="482" y="530" />
        <omgdi:waypoint x="482" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <omgdi:waypoint x="240" y="555" />
        <omgdi:waypoint x="240" y="632" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <omgdi:waypoint x="240" y="708" />
        <omgdi:waypoint x="240" y="785" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <omgdi:waypoint x="265" y="810" />
        <omgdi:waypoint x="482" y="810" />
        <omgdi:waypoint x="482" y="810" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <omgdi:waypoint x="240" y="835" />
        <omgdi:waypoint x="240" y="912" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <omgdi:waypoint x="240" y="988" />
        <omgdi:waypoint x="240" y="1042" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <omgdi:waypoint x="240" y="1138" />
        <omgdi:waypoint x="240" y="1212" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
