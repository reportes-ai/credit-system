<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Defs_Comisiones_Mensuales" targetNamespace="http://autofacil.cl/bpmn">
  <bpmn:process id="Comisiones_Mensuales" name="Cálculo de Comisiones Mensuales" isExecutable="false">
    <bpmn:startEvent id="s" name="Cierre de mes">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t1" name="Calcula comisión por ejecutivo">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g1" name="¿Viene participación en la carta?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t2" name="Usa participación de la carta (manda)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t3" name="Calcula por parámetros (comisiones_variables)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g2" name="">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t4" name="Revisión de comisiones (ejecutivo)">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t5" name="Marca COMISIÓN A PAGAR">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e" name="Comisión pagada">
      <bpmn:incoming>f9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="s" targetRef="t1" />
    <bpmn:sequenceFlow id="f2" sourceRef="t1" targetRef="g1" />
    <bpmn:sequenceFlow id="f3" sourceRef="g1" targetRef="t2" name="Sí" />
    <bpmn:sequenceFlow id="f4" sourceRef="g1" targetRef="t3" name="No" />
    <bpmn:sequenceFlow id="f5" sourceRef="t2" targetRef="g2" />
    <bpmn:sequenceFlow id="f6" sourceRef="t3" targetRef="g2" />
    <bpmn:sequenceFlow id="f7" sourceRef="g2" targetRef="t4" />
    <bpmn:sequenceFlow id="f8" sourceRef="t4" targetRef="t5" />
    <bpmn:sequenceFlow id="f9" sourceRef="t5" targetRef="e" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Comisiones_Mensuales_diagram">
    <bpmndi:BPMNPlane id="Comisiones_Mensuales_plane" bpmnElement="Comisiones_Mensuales">
      <bpmndi:BPMNShape id="s_di" bpmnElement="s">
        <omgdc:Bounds x="222" y="92" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t1_di" bpmnElement="t1">
        <omgdc:Bounds x="160" y="212" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g1_di" bpmnElement="g1" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="365" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t2_di" bpmnElement="t2">
        <omgdc:Bounds x="420" y="352" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t3_di" bpmnElement="t3">
        <omgdc:Bounds x="160" y="492" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g2_di" bpmnElement="g2" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="645" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t4_di" bpmnElement="t4">
        <omgdc:Bounds x="160" y="772" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t5_di" bpmnElement="t5">
        <omgdc:Bounds x="160" y="912" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e_di" bpmnElement="e">
        <omgdc:Bounds x="222" y="1072" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <omgdi:waypoint x="240" y="128" />
        <omgdi:waypoint x="240" y="212" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <omgdi:waypoint x="240" y="288" />
        <omgdi:waypoint x="240" y="365" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <omgdi:waypoint x="265" y="390" />
        <omgdi:waypoint x="420" y="390" />
        <omgdi:waypoint x="420" y="390" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <omgdi:waypoint x="240" y="415" />
        <omgdi:waypoint x="240" y="492" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <omgdi:waypoint x="500" y="428" />
        <omgdi:waypoint x="500" y="670" />
        <omgdi:waypoint x="265" y="670" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <omgdi:waypoint x="240" y="568" />
        <omgdi:waypoint x="240" y="645" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <omgdi:waypoint x="240" y="695" />
        <omgdi:waypoint x="240" y="772" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <omgdi:waypoint x="240" y="848" />
        <omgdi:waypoint x="240" y="912" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <omgdi:waypoint x="240" y="988" />
        <omgdi:waypoint x="240" y="1072" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
