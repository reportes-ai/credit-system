<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Defs_Atencion_Remota" targetNamespace="http://autofacil.cl/bpmn">
  <bpmn:process id="Atencion_Remota" name="Atención Remota de Dealers" isExecutable="false">
    <bpmn:startEvent id="s" name="Dealer solicita cuenta (autoregistro)">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="t1" name="Solicitud PENDIENTE → notifica ejecutivos">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g1" name="¿Aprueba la solicitud?">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="e1" name="RECHAZADA">
      <bpmn:incoming>f3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="t2" name="Crea cuenta + link de acceso (magic link)">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t3" name="Dealer ingresa (login o link, sesión recordada)">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t4" name="Inicia conversación (cola ESPERA)">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t5" name="Ejecutivo toma el chat (ACTIVA, hasta 3 en paralelo)">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="g2" name="¿Requiere video?">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="t6" name="Videollamada WebRTC (audio / video / pantalla)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t7" name="Intercambio de mensajes y documentos">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="t8" name="Cierra conversación (CERRADA)">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="e2" name="Atención finalizada">
      <bpmn:incoming>f13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="s" targetRef="t1" />
    <bpmn:sequenceFlow id="f2" sourceRef="t1" targetRef="g1" />
    <bpmn:sequenceFlow id="f3" sourceRef="g1" targetRef="e1" name="No" />
    <bpmn:sequenceFlow id="f4" sourceRef="g1" targetRef="t2" name="Sí" />
    <bpmn:sequenceFlow id="f5" sourceRef="t2" targetRef="t3" />
    <bpmn:sequenceFlow id="f6" sourceRef="t3" targetRef="t4" />
    <bpmn:sequenceFlow id="f7" sourceRef="t4" targetRef="t5" />
    <bpmn:sequenceFlow id="f8" sourceRef="t5" targetRef="g2" />
    <bpmn:sequenceFlow id="f9" sourceRef="g2" targetRef="t6" name="Sí" />
    <bpmn:sequenceFlow id="f10" sourceRef="t6" targetRef="t7" />
    <bpmn:sequenceFlow id="f11" sourceRef="g2" targetRef="t7" name="No" />
    <bpmn:sequenceFlow id="f12" sourceRef="t7" targetRef="t8" />
    <bpmn:sequenceFlow id="f13" sourceRef="t8" targetRef="e2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Atencion_Remota_diagram">
    <bpmndi:BPMNPlane id="Atencion_Remota_plane" bpmnElement="Atencion_Remota">
      <bpmndi:BPMNShape id="s_di" bpmnElement="s">
        <omgdc:Bounds x="222" y="92" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t1_di" bpmnElement="t1">
        <omgdc:Bounds x="160" y="212" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g1_di" bpmnElement="g1" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="365" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e1_di" bpmnElement="e1">
        <omgdc:Bounds x="482" y="372" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t2_di" bpmnElement="t2">
        <omgdc:Bounds x="160" y="492" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t3_di" bpmnElement="t3">
        <omgdc:Bounds x="160" y="632" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t4_di" bpmnElement="t4">
        <omgdc:Bounds x="160" y="772" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t5_di" bpmnElement="t5">
        <omgdc:Bounds x="160" y="912" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g2_di" bpmnElement="g2" isMarkerVisible="true">
        <omgdc:Bounds x="215" y="1065" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t6_di" bpmnElement="t6">
        <omgdc:Bounds x="420" y="1052" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t7_di" bpmnElement="t7">
        <omgdc:Bounds x="160" y="1192" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t8_di" bpmnElement="t8">
        <omgdc:Bounds x="160" y="1332" width="160" height="76" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="e2_di" bpmnElement="e2">
        <omgdc:Bounds x="222" y="1492" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <omgdi:waypoint x="240" y="128" />
        <omgdi:waypoint x="240" y="212" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <omgdi:waypoint x="240" y="288" />
        <omgdi:waypoint x="240" y="365" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <omgdi:waypoint x="265" y="390" />
        <omgdi:waypoint x="482" y="390" />
        <omgdi:waypoint x="482" y="390" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <omgdi:waypoint x="240" y="415" />
        <omgdi:waypoint x="240" y="492" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <omgdi:waypoint x="240" y="568" />
        <omgdi:waypoint x="240" y="632" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <omgdi:waypoint x="240" y="708" />
        <omgdi:waypoint x="240" y="772" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <omgdi:waypoint x="240" y="848" />
        <omgdi:waypoint x="240" y="912" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <omgdi:waypoint x="240" y="988" />
        <omgdi:waypoint x="240" y="1065" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <omgdi:waypoint x="265" y="1090" />
        <omgdi:waypoint x="420" y="1090" />
        <omgdi:waypoint x="420" y="1090" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <omgdi:waypoint x="500" y="1128" />
        <omgdi:waypoint x="500" y="1230" />
        <omgdi:waypoint x="320" y="1230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <omgdi:waypoint x="240" y="1115" />
        <omgdi:waypoint x="240" y="1192" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12">
        <omgdi:waypoint x="240" y="1268" />
