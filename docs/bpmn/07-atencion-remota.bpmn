      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13">
        <omgdi:waypoint x="240" y="1408" />
        <omgdi:waypoint x="240" y="1492" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
